{
  "expo": {
    "name": "JetLagLess",
    "slug": "JetLagLess",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4ecdd"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4ecdd"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "JetLagLess — Travel sleep planner",
      "shortName": "JetLagLess",
      "description": "A circadian playbook tailored to your flight, your sleep habits, and how your body handles travel.",
      "themeColor": "#1a2945",
      "backgroundColor": "#f4ecdd"
    }
  }
}

